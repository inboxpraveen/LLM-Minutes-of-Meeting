# ═══════════════════════════════════════════════════════════
#  MoM AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Port the web container exposes on the host (Docker Compose)
APP_PORT=5000

# ── Database ─────────────────────────────────────────────────
# SQLite (default — no setup needed, file is auto-created)
# DATABASE_URL=sqlite:///instance/app.db

# PostgreSQL example (swap in for production if desired):
# DATABASE_URL=postgresql+psycopg2://user:password@db:5432/momdb

# ── Redis / Celery ────────────────────────────────────────────
# When running via Docker Compose use the service name "redis"
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# When running locally (no Docker):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── File Upload ───────────────────────────────────────────────
# Maximum upload file size in megabytes
MAX_UPLOAD_SIZE_MB=500

# Path where uploaded recordings are stored (absolute or relative to project root)
# UPLOAD_FOLDER=data/uploads

# ── Default Admin Account ─────────────────────────────────────
# Created automatically on first startup if it doesn't exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_EMAIL=admin@example.com

# ── LLM Provider (OpenAI-compatible) ─────────────────────────
# Works with ANY provider that exposes an OpenAI-compatible API:
#   OpenAI:       https://api.openai.com/v1
#   OpenRouter:   https://openrouter.ai/api/v1
#   Groq:         https://api.groq.com/openai/v1
#   Together AI:  https://api.together.xyz/v1
#   Azure OpenAI: https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   Ollama (local): http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-llm-api-key-here
LLM_MODEL=gpt-4o-mini

# ── Speech-to-Text Provider ───────────────────────────────────
# Options: deepgram | assemblyai | sarvam | elevenlabs
SPEECH_PROVIDER=deepgram

# Deepgram — https://deepgram.com
DEEPGRAM_API_KEY=

# AssemblyAI — https://www.assemblyai.com
ASSEMBLYAI_API_KEY=

# Sarvam AI — https://www.sarvam.ai (great for Indian languages + English)
SARVAM_API_KEY=

# ElevenLabs (Scribe) — https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Meeting Retention ─────────────────────────────────────────
# Uploaded audio/video files are auto-deleted after this many days.
# Transcripts and minutes are NOT deleted — only the raw files.
# Set to a large number (e.g. 3650) to effectively never delete.
MEETING_RETENTION_DAYS=30
